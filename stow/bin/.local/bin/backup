#!/usr/bin/env bash
# Creates a backup copy of a provided file by appending ".bak" to the filename.

set -euo pipefail

if [[ "$#" -eq 0 ]]; then
    echo "Usage: $(basename "$0") <filename_to_backup>" >&2
    exit 1
fi

FILE_TO_BACKUP="$1"
BACKUP_FILE="${FILE_TO_BACKUP}.bak"

if [[ ! -f "$FILE_TO_BACKUP" ]]; then
    echo "Error: File '$FILE_TO_BACKUP' not found." >&2
    exit 1
fi

cp "$FILE_TO_BACKUP" "$BACKUP_FILE"
echo "Backup created successfully: $BACKUP_FILE"
